# ─────────────────────────────────────────────────────────────────────────────────────────────
# Environment variables. Copy this file to `.env.local` and fill in the values.
#   cp .env.example .env.local
# The lead distributes real values via the team password manager — never commit .env.local.
# Only DATABASE_URL and AUTH_SECRET are REQUIRED to boot; the rest enable optional features.
# ─────────────────────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string. MUST be the POOLED host (contains `-pooler`). The direct host
# exhausts connections under Vercel serverless load. Get it from the Neon console → Connection
# Details → "Pooled connection". Each dev migrates against their OWN branch (dev-1..dev-4).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js session encryption secret. Generate one with:  npx auth secret
AUTH_SECRET="replace-with-a-long-random-string"

# ── OPTIONAL: Google OAuth (credentials login works without it) ───────────────────────────────
# Create at https://console.cloud.google.com → Credentials → OAuth client ID (Web application).
# Authorized redirect URI (add ALL you use):
#   http://localhost:3000/api/auth/callback/google
#   https://<your-vercel-preview-and-prod-domains>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── OPTIONAL: Resend email (emails are logged, not sent, if absent) ───────────────────────────
# From https://resend.com → API Keys. Until a domain is verified, the app sends from
# onboarding@resend.dev (see lib/email.ts).
RESEND_API_KEY=""

# ── OPTIONAL: UploadThing file uploads (upload UI disables itself if absent) ──────────────────
# From https://uploadthing.com dashboard → API Keys → the single UPLOADTHING_TOKEN value.
UPLOADTHING_TOKEN=""
# Mirror of the above for the CLIENT (the token is server-only; the client just needs to know
# whether to enable the upload button). Set to "true" when UPLOADTHING_TOKEN is configured.
NEXT_PUBLIC_UPLOADS_ENABLED="false"

# ── PUBLIC: app URL ───────────────────────────────────────────────────────────────────────────
# Used for absolute links (emails, OAuth callbacks, metadata). Set to the deployed URL in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
